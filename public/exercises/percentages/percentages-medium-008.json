  "difficulty": "medium",
  "instructions": "Find the value before tax.",
  "question": {
    "text": "A total bill is $240 after adding 20% sales tax. What was the pre-tax amount?",
    "mathExpression": [
      "$$ \\text{Total} = 120\\% \\text{ of pre-tax amount} $$"
    ]
  },
  "inputs": [
    {
      "name": "preTaxAmount",
      "label": "Pre-tax amount ($) =",
      "inputType": "number",
      "correctAnswer": "200"
    }
  ],
  "hints": [
    "A 20% tax means multiplying the pre-tax value by $$ 1.20 $$.",
    "Set up $$ 1.2x = 240 $$ and solve for $$ x $$."
  ],
  "explanation": {
    "steps": [
      "1. Let the pre-tax amount be $$ x $$.",
      "2. Adding 20% tax gives $$ 1.2x = 240 $$.",
      "3. Divide both sides by $$ 1.2 $$: $$ x = \\frac{240}{1.2} $$.",
      "4. Compute: $$ x = 200 $$.",
      "5. So the pre-tax amount was $$ $200 $$."
    ]
  }
}
