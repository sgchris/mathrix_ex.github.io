  "instructions": "Calculate the percentage decrease.",
  "question": {
    "text": "A town's population dropped from 1250 to 1000. What is the percentage decrease?",
    "mathExpression": [
      "$$ \\text{Percentage decrease} = \\frac{\\text{decrease}}{\\text{original}} \\times 100 $$"
    ]
  },
  "inputs": [
    {
      "name": "percentageDecrease",
      "label": "Percentage decrease (%) =",
      "inputType": "number",
      "correctAnswer": "20"
    }
  ],
  "hints": [
    "First find the decrease: original minus new value.",
    "Then divide by the original value and multiply by 100."
  ],
  "explanation": {
    "steps": [
      "1. Find the decrease: $$ 1250 - 1000 = 250 $$.",
      "2. Divide by the original population: $$ \\frac{250}{1250} = 0.2 $$.",
      "3. Convert to percent: $$ 0.2 \\times 100 = 20\\% $$.",
      "4. The percentage decrease is $$ 20\\% $$."
    ]
  }
}
