  "difficulty": "level05",
  "instructions": "Calculate the percentage increase.",
  "question": {
    "text": "A value increases from 150 to 180. What is the percentage increase?",
    "mathExpression": [
      "$$ \\text{Increase from } 150 \\text{ to } 180 $$"
    ]
  },
  "inputs": [
    {
      "name": "increase",
      "label": "Percentage Increase (%):",
      "inputType": "number",
      "correctAnswer": "20"
    }
  ],
  "hints": [
    "Find the absolute difference.",
    "Divide the difference by the original value and multiply by 100."
  ],
  "explanation": {
    "steps": [
      "1. Find the difference: $$ 180 - 150 = 30 $$.",
      "2. Divide by original: $$ \\frac{30}{150} $$.",
      "3. Convert to percentage: $$ (\\frac{30}{150}) \\times 100 \\approx 20\\% $$."
    ]
  },
