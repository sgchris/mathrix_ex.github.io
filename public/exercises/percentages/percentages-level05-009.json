  "instructions": "Work backward through compound percentage increase.",
  "question": {
    "text": "An investment grows by 10% in year 1 and then 5% in year 2. If it ends at $231, what was the initial amount?",
    "mathExpression": [
      "$$ \\text{Final} = \\text{Initial} \\times 1.10 \\times 1.05 $$"
    ]
  },
  "inputs": [
    {
      "name": "initialAmount",
      "label": "Initial amount ($) =",
      "inputType": "number",
      "correctAnswer": "200"
    }
  ],
  "hints": [
    "Combine the growth factors first: $$ 1.10 \\times 1.05 $$.",
    "Then divide the final amount by the combined factor."
  ],
  "explanation": {
    "steps": [
      "1. Let the initial amount be $$ x $$.",
      "2. After two years: $$ x \\times 1.10 \\times 1.05 = 231 $$.",
      "3. Multiply factors: $$ 1.10 \\times 1.05 = 1.155 $$.",
      "4. Solve: $$ x = \\frac{231}{1.155} = 200 $$.",
      "5. The initial amount was $$ $200 $$."
    ]
  },
  "translations": {
    "he": {
      "topicName": "אחוזים",
      "instructions": "עבדו לאחור בחישוב עלייה מורכבת באחוזים.",
      "question": {
        "text": "השקעה גדלה ב-10% בשנה הראשונה ואז ב-5% בשנה השנייה. אם בסוף הסכום הוא $231, מה היה הסכום ההתחלתי?"
      },
      "inputs": [
        {
          "name": "initialAmount",
          "label": "סכום התחלתי ($) ="
        }
      ],
      "hints": [
        "קודם מחברים את מקדמי הגדילה: $$ 1.10 \\times 1.05 $$.",
        "אחר כך מחלקים את הסכום הסופי במקדם המשולב."
      ],
      "explanation": {
        "steps": [
          "1. נסמן את הסכום ההתחלתי ב-$$ x $$.",
          "2. אחרי שנתיים: $$ x \\times 1.10 \\times 1.05 = 231 $$.",
          "3. כופלים את המקדמים: $$ 1.10 \\times 1.05 = 1.155 $$.",
          "4. פותרים: $$ x = \\frac{231}{1.155} = 200 $$.",
