  "instructions": "Find the percentage.",
  "question": {
    "text": "In a class of 30 students, 6 are absent today. What percentage of students is absent?",
    "mathExpression": [
      "$$ \\text{Absent: } 6 \\quad \\text{Total: } 30 $$"
    ]
  },
  "inputs": [
    {
      "name": "percentage",
      "label": "Percentage (%) =",
      "inputType": "number",
      "correctAnswer": "20"
    }
  ],
  "hints": [
    "To find what percentage one number is of another, divide the part by the total, then multiply by 100.",
    "Divide 6 by 30, then multiply the result by 100."
  ],
  "explanation": {
    "steps": [
      "1. Use the percentage formula: $$ \\text{Percentage} = \\frac{\\text{part}}{\\text{total}} \\times 100 $$.",
      "2. Plug in the values: $$ \\frac{6}{30} \\times 100 $$.",
      "3. Simplify the fraction: $$ \\frac{6}{30} = 0.2 $$.",
      "4. Multiply: $$ 0.2 \\times 100 = 20\\% $$."
    ]
  },
