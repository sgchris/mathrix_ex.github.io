  "question": {
    "text": "What are the values of x and y?",
    "mathExpression": [
      "$$ 4x - 3y = 7 $$",
      "$$ x + y = 7 $$"
    ]
  },
  "inputs": [
    {
      "name": "x",
      "label": "x =",
      "inputType": "number",
      "correctAnswer": "4"
